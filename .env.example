# ===========================================
# W-CRM Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values.
# The start.bat script does this automatically.
# ===========================================

# --- Database ---
# Set to true for local development with SQLite
USE_SQLITE=true

# PostgreSQL settings (used when USE_SQLITE=false)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=saas_crm

# --- Security ---
# Generate a new key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
